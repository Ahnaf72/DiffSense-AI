# =============================================================================
# DiffSense AI - Environment Variables
# Created: [Today's Date]
# IMPORTANT: Never commit this file to GitHub!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=DiffSense AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Backend API Settings
# -----------------------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5000
FRONTEND_URL=http://127.0.0.1:5000

# -----------------------------------------------------------------------------
# Database Configuration (XAMPP MySQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=diffsense_db
DB_USER=diffsense_user
DB_PASSWORD=DiffSense2024!

# Full database URL (don't add spaces!)
DATABASE_URL=mysql+pymysql://diffsense_user:DiffSense2024!@localhost:3306/diffsense_db

# -----------------------------------------------------------------------------
# JWT Configuration (for authentication)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Email Configuration (we'll set this up in Week 2)
# -----------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@diffsense.edu

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=20
UPLOAD_FOLDER=backend/uploads/documents
ALLOWED_EXTENSIONS=pdf,docx,txt

# -----------------------------------------------------------------------------
# AI/ML Settings
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD_GREEN=30
SIMILARITY_THRESHOLD_YELLOW=70