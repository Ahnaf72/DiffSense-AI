# =============================================================================
# DiffSense-AI Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
# All settings have sensible defaults for development.
#
# For production/offline deployment:
#   1. Run: python setup_offline.py
#   2. Set OFFLINE_MODE=true
#   3. Set a strong SECRET_KEY
#   4. Configure MySQL credentials
# =============================================================================

# -----------------------------------------------------------------------------
# OFFLINE MODE SETTINGS
# -----------------------------------------------------------------------------

# Enable offline mode (no internet access assumed)
# Set to 'true' after running setup_offline.py
OFFLINE_MODE=false

# Allow downloading models from HuggingFace Hub
# Set to 'false' in production/air-gapped environments
ALLOW_MODEL_DOWNLOADS=true

# Directory containing pre-downloaded models
# Default: ./models (relative to project root)
MODEL_DIR=./models

# -----------------------------------------------------------------------------
# DATABASE SETTINGS
# -----------------------------------------------------------------------------

# MySQL server hostname
# Use 'mysql' for Docker deployment, 'localhost' for local development
MYSQL_HOST=localhost

# MySQL server port
MYSQL_PORT=3306

# MySQL username
MYSQL_USER=root

# MySQL password (leave empty for no password - NOT recommended for production)
MYSQL_PASSWORD=

# MySQL database name for admin data
MYSQL_DATABASE=admin_db

# -----------------------------------------------------------------------------
# SECURITY SETTINGS (CRITICAL FOR PRODUCTION)
# -----------------------------------------------------------------------------

# Secret key for JWT token signing
# IMPORTANT: Generate a strong random key for production!
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# JWT signing algorithm (do not change unless you know what you're doing)
JWT_ALGORITHM=HS256

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# PATH SETTINGS (Optional - defaults work for most setups)
# -----------------------------------------------------------------------------

# Directory for admin-uploaded reference PDFs
# REFERENCE_DIR=backend/data/reference_pdfs

# Root directory for student PDF uploads
# STUDENT_ROOT=backend/data/user_uploads

# Root directory for teacher PDF uploads
# TEACHER_ROOT=backend/data/teacher_uploads

# Root directory for generated plagiarism reports
# RESULT_ROOT=data/result_pdfs

# Directory for embedding cache files
# EMBED_CACHE_DIR=backend/data/embed_cache_offline

# Directory for FAISS index persistence
# FAISS_INDEX_DIR=backend/data/faiss_indexes

# -----------------------------------------------------------------------------
# PERFORMANCE SETTINGS (Optional - defaults are optimized)
# -----------------------------------------------------------------------------

# Batch size for embedding generation (increase for more GPU memory)
# BATCH_SIZE=256

# Maximum parallel workers for processing
# MAX_WORKERS=4

# Number of BM25 candidates to consider
# BM25_TOP_K=5

# Maximum embeddings to cache in memory
# EMBEDDING_CACHE_SIZE=10000

# =============================================================================
# DOCKER-SPECIFIC OVERRIDES
# =============================================================================
# When using docker-compose, these are typically set via environment section.
# The values below are examples for Docker deployment:
#
# OFFLINE_MODE=true
# ALLOW_MODEL_DOWNLOADS=false
# MODEL_DIR=/app/models
# MYSQL_HOST=mysql
# SECRET_KEY=your-production-secret-key-here
# =============================================================================
