# ── App ──
APP_NAME=DiffSense-AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── CORS ──
# Comma-separated list of allowed origins (leave empty to disable CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Database (Supabase) ──
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.crzymgnpzbdkpsqpaywu.supabase.co:5432/postgres
SUPABASE_URL=https://crzymgnpzbdkpsqpaywu.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_CLI_PATH=supabase

# ── Auth ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# App will refuse to start if empty
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Celery / Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Embedding model ──
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
